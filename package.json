{
  "name": "krarkode",
  "displayName": "krarkode",
  "description": "Ark-focused VS Code extension",
  "version": "0.1.0",
  "license": "MIT",
  "author": "TTTPOB",
  "publisher": "tttpob",
  "icon": "resources/krarkode-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/TTTPOB/krarkode"
  },
  "bugs": {
    "url": "https://github.com/TTTPOB/krarkode/issues"
  },
  "homepage": "https://github.com/TTTPOB/krarkode",
  "changelog": "https://github.com/TTTPOB/krarkode/releases",
  "keywords": [
    "R",
    "Ark",
    "Positron",
    "R language",
    "Plots",
    "Data Explorer"
  ],
  "galleryBanner": {
    "color": "#163a3a",
    "theme": "dark"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:r",
    "onLanguage:rmd",
    "onWebviewPanel:arkPlotManager",
    "onWebviewPanel:krarkode.help"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "language": "r",
        "scopeName": "source.r",
        "path": "./syntaxes/r.tmLanguage.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "krarkode-activity-bar",
          "title": "Krarkode Variables",
          "icon": "resources/variables-icon.svg"
        }
      ]
    },
    "views": {
      "krarkode-activity-bar": [
        {
          "id": "krarkodeVariables",
          "name": "Variables",
          "type": "webview",
          "icon": "resources/variables-icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Krarkode",
      "properties": {
        "krarkode.r.binaryPath": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "default": [],
          "scope": "window",
          "markdownDescription": "Path(s) to R binaries. Can be a single string or an array of paths. Supports `${workspaceFolder}`, `${userHome}` etc. Leave empty to auto-detect."
        },
        "krarkode.pixi.manifestPath": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "Path to `pixi.toml` for R environment discovery. Supports `${workspaceFolder}` etc. Leave empty to use workspace root."
        },
        "krarkode.ark.path": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "Override the Ark executable path. Supports `${workspaceFolder}`, `${userHome}` etc. Leave empty to use the bundled binary (or fall back to `ark` in PATH)."
        },
        "krarkode.ark.logLevel": {
          "type": "string",
          "default": "inherit",
          "enum": [
            "inherit",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Ark backend (sets RUST_LOG=ark=<level>). Use inherit to keep the current RUST_LOG."
        },
"krarkode.ark.console.commandTemplate": {
          "type": "string",
          "default": "{sidecarPath} console --connection-file {connectionFile}",
          "scope": "window",
          "markdownDescription": "Console launch command template. Supports `{sidecarPath}`, `{connectionFile}`. The `RUST_LOG` env var is automatically prepended based on the **Ark: Log Level** setting."
        },
        "krarkode.ark.kernel.commandTemplate": {
          "type": "string",
          "default": "{arkPath} --connection_file {connectionFile} --session-mode console --startup-file {startupFile}",
          "scope": "window",
          "markdownDescription": "Ark kernel command template. Supports {arkPath}, {connectionFile}, {startupFile}."
        },
        "krarkode.ark.kernel.startupFileTemplate": {
          "type": "string",
          "default": "{sessionsDir}/{name}/init-ark.R",
          "scope": "window",
          "markdownDescription": "Ark kernel startup file template. Supports {sessionsDir} and {name}."
        },
        "krarkode.ark.sidecar.path": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "Override the Ark sidecar executable path. Supports `${workspaceFolder}`, `${userHome}` etc."
        },
        "krarkode.ark.sidecar.timeoutMs": {
          "type": "number",
          "default": 30000,
          "scope": "window",
          "markdownDescription": "Timeout for Ark sidecar startup, in milliseconds."
        },
        "krarkode.ark.sidecar.ipAddress": {
          "type": "string",
          "default": "127.0.0.1",
          "scope": "window",
          "markdownDescription": "IP address used for Ark sidecar/LSP connections."
        },
        "krarkode.ark.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Enable the Ark language server."
        },
        "krarkode.ark.lsp.timeoutMs": {
          "type": "number",
          "default": 15000,
          "scope": "window",
          "markdownDescription": "Timeout for Ark LSP sidecar startup, in milliseconds."
        },
        "krarkode.ark.tmux.path": {
          "type": "string",
          "default": "tmux",
          "scope": "window",
          "markdownDescription": "tmux executable path for Ark console sessions. Supports `${workspaceFolder}`, `${userHome}` etc."
        },
        "krarkode.ark.tmux.manageKernel": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Automatically start the Ark kernel inside tmux."
        },
        "krarkode.plot.viewColumn": {
          "type": "string",
          "default": "Two",
          "enum": [
            "Active",
            "Beside",
            "One",
            "Two",
            "Three",
            "Disable"
          ],
          "scope": "window",
          "markdownDescription": "Where to show plots, or disable plot display."
        },
        "krarkode.plot.maxHistory": {
          "type": "number",
          "default": 50,
          "scope": "window",
          "markdownDescription": "Maximum number of plots to keep in history."
        },
        "krarkode.html.viewColumn": {
          "type": "string",
          "default": "Two",
          "enum": [
            "Active",
            "Beside",
            "One",
            "Two",
            "Three"
          ],
          "scope": "window",
          "markdownDescription": "Where to show HTML viewer panels."
        },
        "krarkode.source.encoding": {
          "type": "string",
          "default": "UTF-8",
          "scope": "window",
          "markdownDescription": "Encoding used for source() when running files."
        },
        "krarkode.source.echo": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "markdownDescription": "Echo code when sourcing files."
        },
        "krarkode.terminal.bracketedPaste": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "Use bracketed paste mode when sending code to the terminal. Wraps multi-line code with ANSI escape sequences so the terminal treats it as a single paste. Disable if your terminal does not support it."
        },
        "krarkode.terminal.sendDelay": {
          "type": "integer",
          "default": 8,
          "scope": "window",
          "markdownDescription": "Delay in milliseconds between sending each line to the terminal. Only used when `#krarkode.terminal.bracketedPaste#` is disabled."
        },
        "krarkode.logging.runtime": {
          "type": "string",
          "default": "error",
          "enum": [
            "none",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable the Krarkode Runtime output channel.",
            "Show errors only.",
            "Show warnings and errors.",
            "Show info/warn/error messages.",
            "Show verbose logs (debug/info/warn/error).",
            "Show trace logs (trace/debug/info/warn/error)."
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Krarkode Runtime output channel (session lifecycle, kernel startup, code execution)."
        },
        "krarkode.logging.ui": {
          "type": "string",
          "default": "error",
          "enum": [
            "none",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable the Krarkode UI output channel.",
            "Show errors only.",
            "Show warnings and errors.",
            "Show info/warn/error messages.",
            "Show verbose logs (debug/info/warn/error).",
            "Show trace logs (trace/debug/info/warn/error)."
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Krarkode UI output channel (plots, variables, data explorer, help, HTML viewer)."
        },
        "krarkode.logging.arkKernel": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable the Krarkode Kernel output channel.",
            "Show errors only.",
            "Show warnings and errors.",
            "Show info/warn/error messages.",
            "Show verbose logs (debug/info/warn/error).",
            "Show trace logs (trace/debug/info/warn/error)."
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Krarkode Kernel output channel (Ark kernel stdout/stderr)."
        },
        "krarkode.logging.lsp": {
          "type": "string",
          "default": "error",
          "enum": [
            "none",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable the Krarkode LSP output channel.",
            "Show errors only.",
            "Show warnings and errors.",
            "Show info/warn/error messages.",
            "Show verbose logs (debug/info/warn/error).",
            "Show trace logs (trace/debug/info/warn/error)."
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Krarkode LSP output channel (language server protocol operations)."
        },
        "krarkode.logging.sidecar": {
          "type": "string",
          "default": "error",
          "enum": [
            "none",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable the Krarkode Sidecar output channel.",
            "Show errors only.",
            "Show warnings and errors.",
            "Show info/warn/error messages.",
            "Show verbose logs (debug/info/warn/error).",
            "Show trace logs (trace/debug/info/warn/error)."
          ],
          "scope": "window",
          "markdownDescription": "Log level for the Krarkode Sidecar output channel (sidecar process events and stderr)."
        }
      }
    },
    "commands": [
      {
        "command": "krarkode.createArkSession",
        "title": "Create Ark Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.attachArkSession",
        "title": "Use Session from Current Console",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.openArkConsole",
        "title": "Open Console for Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.stopArkSession",
        "title": "Stop Ark Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.interruptArkSession",
        "title": "Interrupt Ark Session (Send Ctrl+C)",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.showArkSessionMenu",
        "title": "Show Ark Session Menu",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.switchArkSession",
        "title": "Switch Ark Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.interruptActiveArkSession",
        "title": "Interrupt Active Ark Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.stopActiveArkSession",
        "title": "Stop Active Ark Session",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.copyArkConnectionFile",
        "title": "Copy Ark Connection File",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.restartArkLanguageServer",
        "title": "Restart Ark Language Server",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.doctor",
        "title": "Doctor (Check Environment)",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runSelection",
        "title": "Run Selection/Line",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runSelectionRetainCursor",
        "title": "Run Selection/Line (Retain Cursor)",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runSource",
        "title": "Source File",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runSourceWithEcho",
        "title": "Source File with Echo",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runFromLineToEnd",
        "title": "Run From Line To End",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.runFromBeginningToLine",
        "title": "Run From Beginning To Line",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.nrow",
        "title": "nrow()",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.length",
        "title": "length()",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.head",
        "title": "head()",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.thead",
        "title": "t(head())",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.names",
        "title": "names()",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.view",
        "title": "View()",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.plot.previous",
        "title": "Previous Plot",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.plot.next",
        "title": "Next Plot",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.plot.save",
        "title": "Save Current Plot",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.plot.openInBrowser",
        "title": "Open Plot in Browser",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.plot.clear",
        "title": "Clear Plot History",
        "category": "Krarkode"
      },
      {
        "command": "krarkode.help.open",
        "title": "Open Help Panel",
        "category": "Help"
      },
      {
        "command": "krarkode.help.showAtCursor",
        "title": "Look Up Help at Cursor",
        "category": "Help"
      },
      {
        "command": "krarkode.help.goBack",
        "title": "Go Back in Help",
        "category": "Help"
      },
      {
        "command": "krarkode.help.goForward",
        "title": "Go Forward in Help",
        "category": "Help"
      },
      {
        "command": "krarkode.help.goHome",
        "title": "Go Home",
        "category": "Help"
      }
    ],
    "keybindings": [
      {
        "command": "krarkode.runSelection",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == r"
      },
      {
        "command": "krarkode.runSelection",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && editorLangId == rmd"
      },
      {
        "command": "krarkode.runSource",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "editorTextFocus && editorLangId == r"
      },
      {
        "command": "krarkode.help.open",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "editorTextFocus"
      },
      {
        "command": "krarkode.help.showAtCursor",
        "key": "f1",
        "when": "editorTextFocus && editorLangId == r"
      }
    ]
  },
  "scripts": {
    "clean": "pnpm exec rimraf dist",
    "generate:data-explorer-types": "node scripts/generate-data-explorer-types.mjs",
    "generate:sidecar-event-types": "node scripts/generate-sidecar-event-types.mjs",
    "generate:types": "node scripts/generate-data-explorer-types.mjs && node scripts/generate-sidecar-event-types.mjs",
    "build:extension": "vite build",
    "build:dataexplorer": "vite build --config vite.dataexplorer.config.ts",
    "build:variables": "vite build --config vite.variables.config.ts",
    "build:plotviewer": "vite build --config vite.plotviewer.config.ts",
    "build": "pnpm run generate:types && pnpm run build:extension && pnpm run build:dataexplorer && pnpm run build:variables && pnpm run build:plotviewer",
    "compile": "pnpm run build",
    "compile:dev": "pnpm run build",
    "watch:extension": "vite build --watch",
    "watch:data-explorer": "vite build --config vite.dataexplorer.config.ts --watch",
    "watch:variables": "vite build --config vite.variables.config.ts --watch",
    "watch:plotviewer": "vite build --config vite.plotviewer.config.ts --watch",
    "typecheck": "pnpm exec tsc --noEmit",
    "lint": "pnpm exec eslint \"src/**/*.{ts,svelte}\"",
    "format": "pnpm exec prettier --write .",
    "download:ark": "node scripts/download-ark.mjs",
    "stage:sidecar": "node scripts/stage-sidecar.mjs",
    "package": "pnpm exec vsce package --no-dependencies",
    "package:full": "node scripts/package-full.mjs",
    "test:unit": "vitest run",
    "test:dataexplorer:bundle-smoke": "pnpm run build:dataexplorer && node scripts/data-explorer-bundle-smoke.mjs",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:compile": "pnpm exec tsc -p tsconfig.test.json && node scripts/prepare-test-dist.mjs",
    "test": "pnpm run test:unit && pnpm run build && pnpm run test:compile && node ./dist-test/test/runTest.js",
    "vscode:prepublish": "pnpm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "mocha": "^10.4.0",
    "prettier": "^3.3.3",
    "quicktype-core": "^23.2.6",
    "rimraf": "^5.0.5",
    "svelte-eslint-parser": "^1.0.0",
    "svelte-preprocess": "^6.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/virtual-core": "^3.13.18",
    "@vscode/codicons": "^0.0.36",
    "echarts": "^5.6.0",
    "smol-toml": "^1.6.0",
    "svelte": "^5.0.0",
    "vscode-languageclient": "^9.0.1"
  }
}
